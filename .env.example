# Local dev: point at your local or EC2 API
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# --- Vercel (recommended: HTTPS page → proxy → HTTP API on EC2) ---
# In Vercel Project → Settings → Environment Variables, set:
#   BACKEND_PROXY_URL=http://YOUR_EC2_PUBLIC_IP:8000
#   NEXT_PUBLIC_API_URL=/backend-api
# HTTPS site + http:// API: browsers block ws:// (mixed content). Either use BACKEND_PROXY_URL
# + NEXT_PUBLIC_API_URL=/backend-api so WS goes via same origin, or set TLS on the API and:
#   NEXT_PUBLIC_WS_URL=wss://api.yourdomain.com
